# Telegram Bot
BOT_TOKEN=your_bot_token_here
BOT_ADMIN_IDS=123456789,987654321

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/uniquer_bot

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Subscription Check
SUBSCRIPTION_CHANNEL_ID=-1001234567890
SUBSCRIPTION_CHANNEL_USERNAME=username

# Paths
STORAGE_INPUT_PATH=./storage/input
STORAGE_OUTPUT_PATH=./storage/output

# Video Processing
FFMPEG_PATH=ffmpeg
MAX_VIDEO_SIZE_MB=50
PROCESSING_TIMEOUT_SECONDS=300
